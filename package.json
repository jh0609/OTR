    "tiles:process": "node tools/chroma-key.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "~4.19.0",
    "typescript": "~5.6.0",
    "vite": "~6.0.0",
    "vitest": "~2.0.0"
  },
  "dependencies": {
    "phaser": "~3.80.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5"
  }
