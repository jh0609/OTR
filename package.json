{
  "name": "over-the-rainbow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "tsx tools/run-sim.ts",
    "analyze:tail": "tsx tools/analyze-tail-jsonl.ts --out out/tail-full-analysis.txt",
